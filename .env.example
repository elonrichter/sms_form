# =============================================================================
# SMS Subscription Form — environment variables (SPEC 01 §1.1)
# Copy to `.env.local` for local dev, or set these in the Vercel project.
# A reskin = swap src/config/theme.ts + src/config/brand.config.ts + these vars.
# =============================================================================

# --- SECRET (server-only — must NEVER reach the browser bundle) ---------------
# Base URL of the Aggregator API.
AGGREGATOR_API_URL=https://api.yourdomain.com
# Per-brand bearer token. The Aggregator maps it to a brand server-side.
AGGREGATOR_API_TOKEN=tok_live_replace_me

# --- Brand identity / disclosure interpolation --------------------------------
# Sanity-check value forwarded in the body (the token is authoritative).
BRAND_SLUG=richmondbalance
# Interpolated into the compliance disclosure copy.
BRAND_NAME=Richmond Balance
# Link targets rendered in the disclosure.
SMS_TERMS_URL=https://richmondbalance.com/sms-terms
PRIVACY_URL=https://richmondbalance.com/privacy
# Versions the exact disclosure copy snapshot.
CONSENT_TEXT_VERSION=richmondbalance-v1
# Default dial-code selection (US or CA are in scope; both are +1 / NANP).
DEFAULT_COUNTRY=US

# --- Optional anti-abuse (Cloudflare Turnstile) -------------------------------
# If CAPTCHA_SECRET is set, the server requires a valid token on submit.
# CAPTCHA_SITE_KEY=0x4AAAAAAA...
# CAPTCHA_SECRET=0x4AAAAAAA...
